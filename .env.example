# ─── API KEYS ────────────────────────────────────────────────────────────────

# Anthropic (Claude AI) — Required for AI analysis
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Financial Modeling Prep — For global stock data
# Free tier: 250 calls/day | Get from: https://financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage — Backup financial data source
# Free tier: 25 calls/day | Get from: https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED (Federal Reserve) — For macro indicators
# Free | Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# World Bank / IMF — No key needed (free public API)

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
MAX_PEERS=5

# ─── DATA SOURCES CONFIG ─────────────────────────────────────────────────────
# Primary source: fmp | yfinance | alpha_vantage
PRIMARY_DATA_SOURCE=fmp

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
ENABLE_MACRO_ANALYSIS=true
ENABLE_PRIVATE_COMPANY=true
ENABLE_PDF_EXPORT=true
ENABLE_WEBSOCKET_PRICES=false
